# MILA OFFICE — Настройки
# Сохрани этот файл как .env в папке E:\MILA GOLD\  (общий для агентов и tools/)
# НИКОМУ НЕ ПОКАЗЫВАЙ ЭТОТ ФАЙЛ — это секреты.
#
# Код принимает и канонические, и legacy-имена (через fallback). Канонические — ниже.
# Если у тебя уже есть tools/.env со старыми именами (ANTHROPIC_KEY, TELEGRAM_API) —
# он продолжит работать, переименовывать не обязательно.

# ── Anthropic (Claude) — ОБЯЗАТЕЛЬНО ─────────────────────
ANTHROPIC_API_KEY=sk-ant-...твой_ключ...
# legacy-алиас, тоже читается: ANTHROPIC_KEY
#
# Альтернатива ключу (опц.): у Messages API нет публичного OAuth, но можно ходить
# через шлюз/прокси по bearer-токену. Если задан ANTHROPIC_AUTH_TOKEN — клиент
# использует Authorization: Bearer вместо x-api-key.
# ANTHROPIC_AUTH_TOKEN=...
# ANTHROPIC_BASE_URL=https://your-gateway.example   # опц., переопределяет базовый URL

# ── Instagram (Graph / Instagram Login) ─────────────────
IG_ACCESS_TOKEN=долгосрочный_токен_60_дней
IG_USER_ID=id_инстаграм_аккаунта
# IG_API_FLOW=facebook            # или instagram_login
# legacy-алиасы, тоже читаются: INSTAGRAM_ACCESS_TOKEN, INSTAGRAM_BUSINESS_ACCOUNT_ID

# ── Telegram (нужен агенту Тёма) ────────────────────────
TELEGRAM_BOT_TOKEN=токен_бота_из_BotFather
# legacy-алиас, тоже читается: TELEGRAM_API

# ── Gumroad (нужен агентам Дима и Лера) ─────────────────
GUMROAD_ACCESS_TOKEN=токен_gumroad
# legacy-алиас, тоже читается: GUMROAD_TOKEN

# ── Рабочая папка (опционально, если не E:\MILA GOLD) ──
# MILA_FOLDER=E:\MILA GOLD

# --- LLM routing -------------------------------------------------
# Gemini is used for most heavy agent work when GEMINI_KEY is present.
# Claude is still used for selected agents that need extra reasoning.
GEMINI_KEY=AIza...your_google_ai_key...
MILA_LLM_PROVIDER=gemini
MILA_GEMINI_MODEL=gemini-2.5-flash
MILA_ANTHROPIC_AGENTS=manager,producer

# --- Gamma branded product generation ----------------------------
GAMMA_API_KEY=skgamma-xxxxxxxx
GAMMA_THEME_ID=
# Create the "MILA Brand" theme in Gamma manually, then paste theme_id here.
# Optional async polling controls:
# GAMMA_POLL_SEC=10
# GAMMA_TIMEOUT_SEC=900
