# ============================================================
# MILA GOLD — Instagram / Meta API credentials
# ============================================================
# СКОПИРУЙТЕ этот файл в ".env" (в той же папке) и впишите свои
# значения. Файл .env НИКОГДА не отправляйте в чат и не
# выкладывайте в интернет — он содержит секреты.
#
# Copy this file to ".env" and fill in your values.
# NEVER share .env in chat or commit it anywhere.
# ============================================================

# --- Обязательно / Required ---------------------------------

# Способ подключения Instagram:
#   instagram_login — новый «Instagram API with Instagram Login»
#                     (graph.instagram.com, БЕЗ Facebook-страницы)
#   facebook        — старый «Instagram Graph API» через FB-страницу
#                     (graph.facebook.com, нужен IG_USER_ID + связанная страница)
IG_API_FLOW=instagram_login

# Токен доступа Instagram.
#   instagram_login: вкладка приложения «Instagram» → Generate token.
#   facebook:        долгоживущий Page-токен из Graph API Explorer.
IG_ACCESS_TOKEN=

# ID Instagram-аккаунта. Для instagram_login НЕОБЯЗАТЕЛЕН (узел "me").
# Для facebook ОБЯЗАТЕЛЕН — это число (Instagram Business Account ID), НЕ username.
# check_setup.py --write подставит его автоматически.
IG_USER_ID=

# --- Необязательно / Optional -------------------------------

# ID Facebook-страницы, привязанной к Instagram (нужен для
# некоторых запросов и для DMs через Messenger Platform).
FB_PAGE_ID=

# App ID и App Secret вашего приложения в Meta for Developers.
# Нужны только для обновления (refresh) долгоживущего токена.
META_APP_ID=988885350216945
META_APP_SECRET=8139ff2b6f522c46bd2089cce059cf63

# Версия Graph API. Можно не менять.
GRAPH_API_VERSION=v21.0

# --- Threads (отдельный API!) -------------------------------
# Threads API — ОТДЕЛЬНОЕ приложение от Instagram/Facebook, свой
# токен и хост (graph.threads.net). Нужно только если используете
# post_threads.py / get_threads.py.
# Создать приложение: https://developers.facebook.com (use case «Threads»).

# Долгоживущий токен Threads и ID аккаунта Threads (обязательно).
THREADS_ACCESS_TOKEN=
THREADS_USER_ID=

# App ID / Secret приложения Threads (для refresh токена).
THREADS_APP_ID=
THREADS_APP_SECRET=

# Версия Threads API. Можно не менять.
THREADS_API_VERSION=v1.0

# --- Supabase (для живого дашборда) -------------------------
# Нужно только для upload_to_supabase.py — заливки данных в таблицу
# ig_posts, которую читает живой дашборд в Cowork.
# URL проекта: Supabase → Project Settings → Data API → Project URL.
SUPABASE_URL=https://eeyakhdqrwxnwqaobdub.supabase.co

# SERVICE ROLE ключ (НЕ anon!): Project Settings → API keys → service_role.
# Это секрет — даёт полный доступ к базе. В чат не отправлять.
SUPABASE_SERVICE_KEY=

# --- MILA Office LLM routing -------------------------------------
# Gemini handles the heavy agent work when configured. Claude is kept for
# selected agents that need extra reasoning.
GEMINI_KEY=
MILA_LLM_PROVIDER=gemini
MILA_GEMINI_MODEL=gemini-2.5-flash
MILA_ANTHROPIC_AGENTS=manager,producer

# --- n8n / Telegram notifications --------------------------------
# If N8N_DONE_WEBHOOK is empty, mila-office/pipeline.py --notify sends the
# completion signal directly to Telegram so Ludmila still sees agent updates.
N8N_DONE_WEBHOOK=
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# --- Gamma branded product generation ----------------------------
GAMMA_API_KEY=skgamma-xxxxxxxx
GAMMA_THEME_ID=
# Optional async polling controls:
# GAMMA_POLL_SEC=10
# GAMMA_TIMEOUT_SEC=900

# --- Shared API rate limits --------------------------------------
# Local safety limit shared through mila-office/memory/rate_limits.json.
IG_RATE_LIMIT_PER_HOUR=200
THREADS_RATE_LIMIT_PER_HOUR=200
